  <regex offset="after_parent">^(\.+) filterlog \d+ - - \d+,,,\d+,(\w+),\w+,(\w+),(\w+),\d+,\S+,,\d+,\d+,\d+,\w+,\d+,(\w+),\d+,(\S+),(\S+),(\S+),(\S+),\d+</r>
  <order>router,interface,firewallaction,direction,protocol,srcip,dstip,srcport,dstport</order>
